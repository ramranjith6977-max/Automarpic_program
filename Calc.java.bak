import java.util.Scanner;
class Calc 
{
	static Scanner sc = new Scanner(System.in);
	public static void main(String[] args) 
	{
		System.out.println("\t\t Calculator");
		System.out.println("\n 1.Addition \n2.Subtraction \n3. Multiplication \n4. Division \n5. Modulus");
		System.out.print("Select any option ");
		int option = sc.nextInt();
		
		int num1;
		int num2;
		
		switch(option)
		{
			case 1 : System.out.println("welcome to addition operator");
					 System.out.print("Enter first value: ");
					 num1 = sc.nextInt();
					 System.out.print("Enter second value:");
					 num2 = sc.nextInt();
					 System.out.print("Addition: "+(num1 + num2));
					 break;
			
			case 2 : System.out.println("welcome to Subtraction operator");
					 System.out.print("Enter first value: ");
					 num1 = sc.nextInt();
					 System.out.print("Enter second value:");
					 num2 = sc.nextInt();
					 System.out.println("Subtraction" +(num1 - num2));
					 break;
			
			case 3: System.out.println("welcome to Multiplication operator");
					System.out.print("Enter first value: ");
					num1 = sc.nextInt();
					System.out.print("Enter second value:");
					num2 = sc.nextInt();
					System.out.println("Multiplication" +(num1 * num2));
					break;
			
			case 4: System.out.println("welcome to Division operator");
					System.out.print("Enter first value: ");
					num1 = sc.nextInt();
					System.out.print("Enter second value:");
					num2 = sc.nextInt();
					if (num2 == 0)
					{
						System.out.println("cannot divide by zero");
					}
					else
					{
						System.out.print("Division" +(num1 / num2));
					}
					break;
			
			case 5: System.out.println("welcome to Modulus operator");
					System.out.print("Enter first value: ");
					num1 = sc.nextInt();
					System.out.print("Enter second value:");
					num2 = sc.nextInt();
					System.out.println("Modulus" +(num1 % num2));
					break;
			
		    default : System.out.println("Invalid value");
			
		}
	}
	
}
